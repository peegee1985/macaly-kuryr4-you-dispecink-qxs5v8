{
  "expo": {
    "name": "Kuryr4You Řidič",
    "slug": "kuryr4you-ridic",
    "scheme": "kuryr4you",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F111A",
    "primaryColor": "#F59E0B",
    "icon": "./assets/icon.png",
    "android": {
      "package": "cz.kuryr4you.driver",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0F111A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA"
      ],
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kuryr4You používá polohu během aktivní směny pro dispečink a navigaci.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kuryr4You potřebuje přístup k fotografiím pro doklad o doručení.",
          "cameraPermission": "Kuryr4You potřebuje fotoaparát pro doklad o doručení a fotodokumentaci."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "./plugins/withStandaloneApk",
      "expo-font"
    ]
  }
}
