{
  "expo": {
    "name": "Kuryr4You Řidič",
    "slug": "kuryr4you-ridic",
    "scheme": "kuryr4you",
    "version": "0.7.1",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F111A",
    "primaryColor": "#F59E0B",
    "icon": "./assets/icon.png",
    "androidStatusBar": {
      "backgroundColor": "#0F111A",
      "barStyle": "light-content",
      "translucent": false
    },
    "android": {
      "package": "cz.kuryr4you.driver",
      "versionCode": 9,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F111A"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.CAMERA"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kuryr4You používá polohu během aktivní směny pro dispečink a navigaci.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F59E0B",
          "defaultChannel": "k4y-driver-status"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kuryr4You potřebuje přístup k fotografiím pro doklad o doručení.",
          "cameraPermission": "Kuryr4You potřebuje fotoaparát pro doklad o doručení a fotodokumentaci."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "./plugins/withStandaloneApk",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "5fa12682-2a6c-4798-96e5-8b7f3f9bf241"
      }
    },
    "owner": "peegee85"
  }
}
