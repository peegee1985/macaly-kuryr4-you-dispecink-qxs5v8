{
  "expo": {
    "name": "Kuryr4You Zakaznik",
    "slug": "kuryr4you-zakaznik",
    "scheme": "kuryr4you-customer",
    "version": "1.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F111A",
    "primaryColor": "#F59E0B",
    "icon": "./assets/icon.png",
    "android": {
      "package": "cz.kuryr4you.customer",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F111A"
      },
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ],
      "predictiveBackGestureEnabled": true
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#F59E0B",
          "defaultChannel": "k4y-customer"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "./plugins/withCustomerAppName",
      "./plugins/withStandaloneApk",
      "expo-font"
    ]
  }
}
